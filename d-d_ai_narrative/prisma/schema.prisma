// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client"
  output          = "../app/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  username   String      @unique
  password   String
  characters Character[]
  profile  Profile?

  hostedRooms Room[]       @relation("RoomHost")
  roomPlayers RoomPlayer[]
  campaigns   Campaign[]   @relation("CampaignCreator")
}

model Profile {
  id               String          @id @default(cuid())
  userId           String          @unique
  avatarUrl        String          @default("")
  bio              String          @default("")
  language         ProfileLanguage @default(FR)
  darkMode         Boolean         @default(false)
  totalGames       Int             @default(0)
  totalTurns       Int             @default(0)
  monstersDefeated Int             @default(0)
  naturalCrits     Int             @default(0)
  updatedAt        DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Stocke les souvenirs narratifs du Dungeon Master IA
// (actions des joueurs, événements, PNJ rencontrés, lore D&D...)
model Memory {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Texte brut du souvenir (ex: "Le joueur Thorin a tué le dragon rouge")
  content String

  // Type de souvenir pour filtrer les recherches
  type MemoryType @default(EVENT)

  // Identifiant de la session de jeu
  sessionId String?

  // Vecteur d'embedding généré par le LLM (1536 dims pour OpenAI, 768 pour modèles open-source)
  embedding Unsupported("vector(1536)")?
}

model Character {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  name  String
  race  Race
  class CharClass

  strength     Int
  dexterity    Int
  constitution Int
  intelligence Int
  wisdom       Int
  charisma     Int

  maxHp      Int
  currentHp  Int
  armorClass Int
  xp         Int @default(0)
  level      Int @default(1)

  @@unique([userId, name])

  roomPlayers RoomPlayer[]
}

enum Race {
  HUMAN
  ELF
  DWARF
  HALF_ORC
  TIEFLING
  HALFLING
}

enum CharClass {
  FIGHTER
  MAGE
  ROGUE
  CLERIC
  BARD
  RANGER
}

enum RoomStatus {
  WAITING     // En attente de joueurs
  IN_PROGRESS // Partie en cours
  FINISHED    // Partie terminée
}

enum ActionMode {
  VOTE // Décision collective par vote
  FREE // Action libre directe
}

model Room {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  code       String     @unique
  name       String
  status     RoomStatus @default(WAITING)
  actionMode ActionMode @default(VOTE)
  maxPlayers Int        @default(6)

  hostId String
  host   User   @relation("RoomHost", fields: [hostId], references: [id])

  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])

  players RoomPlayer[]

  @@map("rooms")
}

model RoomPlayer {
  id       String   @id @default(cuid())
  joinedAt DateTime @default(now())

  roomId      String
  userId      String
  characterId String?
  isReady     Boolean @default(false)

  room      Room       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id])
  character Character? @relation(fields: [characterId], references: [id])

  @@unique([roomId, userId])
  @@map("room_players")
}

enum MemoryType {
  EVENT // Action d'un joueur ou événement narratif
  LORE // Information sur l'univers D&D
  NPC // Données sur un PNJ
  QUEST // Quête ou objectif
  RULE // Règle de jeu
}

enum ProfileLanguage {
  FR
  EN
}

enum CampaignTheme {
  HORROR        // Horreur et suspense
  HEROIC        // Aventure héroïque classique
  MYSTERY       // Mystère et investigation
  INVESTIGATION // Enquête et déduction
}

enum CampaignDifficulty {
  EASY   // Accessible aux débutants
  MEDIUM // Expérience D&D recommandée
  HARD   // Joueurs confirmés
}

model VectorDocument {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  source    String
  chunk     String
  type      MemoryType

  embedding Unsupported("vector(1536)")?

  @@index([type])
  @@map("vector_documents")
}

model Campaign {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creatorId String
  creator   User   @relation("CampaignCreator", fields: [creatorId], references: [id])

  title             String
  synopsis          String
  startLocation     String
  mainQuest         String
  systemPrompt      String
  theme             CampaignTheme
  difficulty        CampaignDifficulty
  minPlayers        Int                @default(2)
  maxPlayers        Int                @default(6)
  estimatedDuration Int
  isPublic          Boolean            @default(true)
  isPremium         Boolean            @default(false)

  rooms Room[]

  @@index([isPublic, isPremium])
  @@map("campaigns")
}
